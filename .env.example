# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=light-dtm-starter
DEBUG=false
LOG_LEVEL=INFO

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
# Set OPENAI_API_KEY to enable LLM-based signal extraction.
# Leave blank to use the built-in keyword heuristics (no external call needed).
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT=10.0
LLM_ENABLED=true

# ── Decision Executor ─────────────────────────────────────────────────────────
# DECISION_MODE: "local" (default) | "orchestrator"
#   local        — in-process execution, no external call required
#   orchestrator — HTTP call to ORCHESTRATOR_ENDPOINT; falls back to local on error
DECISION_MODE=local
ORCHESTRATOR_ENDPOINT=
ORCHESTRATOR_TIMEOUT=5.0

# ── Trace Store ───────────────────────────────────────────────────────────────
# TRACE_MODE: "file" (default) | "ledger"
#   file   — writes traces/traces.jsonl + traces/exports/ locally
#   ledger — HTTP POST to LEDGER_ENDPOINT; falls back to file on error
TRACE_MODE=file
TRACE_STORE_PATH=traces/traces.jsonl
LEDGER_ENDPOINT=
LEDGER_TIMEOUT=5.0
